{
  "name": "ministry-of-testing-playwright",
  "version": "1.0.0",
  "private": true,
  "description": "Public, non-destructive Playwright smoke tests for Ministry of Testing",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test tests/ui --headed",
    "test:debug": "playwright test tests/ui --debug",
    "test:allure": "playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "dotenv": "^17.2.0"
  }
}
